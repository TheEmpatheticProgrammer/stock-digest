# ─── Tastytrade OAuth2 ────────────────────────────────────────────────────────
# Register an OAuth2 app at https://developer.tastytrade.com
# Use the Authorization Code flow to obtain a refresh token
TASTYTRADE_CLIENT_ID=your_client_id
TASTYTRADE_CLIENT_SECRET=your_client_secret
TASTYTRADE_REFRESH_TOKEN=your_refresh_token

# ─── Finnhub ──────────────────────────────────────────────────────────────────
# Free tier: 60 req/min — sufficient but slow for 500 stocks
# Starter tier ($25/mo, 300 req/min): recommended for <10 min scans
# Register at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key

# ─── FRED (Federal Reserve Economic Data) ────────────────────────────────────
# Free — register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# ─── Reddit OAuth2 (script app) ───────────────────────────────────────────────
# Create a "script" type app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=stock-digest/1.0.0 by /u/your_username

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
